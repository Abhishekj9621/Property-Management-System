NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

DATABASE_URL=postgresql://hms_user:hms_password@localhost:5432/hms_db?schema=public

REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated allow-list — this one backend serves TWO browser apps:
# the internal management app and the public marketing site.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Used to build links in staff emails (password reset, etc.) — always the
# management app, never the public site. Defaults to the first CORS_ORIGINS
# entry if left blank.
MANAGEMENT_APP_URL=http://localhost:5173

STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
EMAIL_FROM="NovaStay Hotels <no-reply@novastay.com>"
# Where curatdconcepts.com's contact form / partner inquiry emails land.
# Falls back to SMTP_USER if left blank.
CONTACT_INBOX_EMAIL=business@curatdconcepts.com

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Notifications (added) ---
# SMTP_HOST left blank uses a JSON dev transport (emails logged, not sent)

# --- Public website photo uploads (Cloudflare R2) ---
# Create a bucket + API token at https://dash.cloudflare.com/?to=/:account/r2
# R2_PUBLIC_URL is the bucket's public r2.dev URL (or a custom domain you've
# mapped to it) — no trailing slash.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=curatd-property-photos
R2_PUBLIC_URL=
